# ─────────────────────────────────────────────────────────
# GRASSION — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
# Get this from Railway, Supabase, or your own Postgres instance
DATABASE_URL=postgresql://user:password@localhost:5432/grassion

# CORS — comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Optional: Email notifications for new signups
# (add nodemailer if you want email alerts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=you@gmail.com
